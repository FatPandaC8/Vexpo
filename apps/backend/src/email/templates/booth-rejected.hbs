<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <style>
    body { font-family: sans-serif; background: #f8fafc; margin: 0; padding: 0; }
    .card { max-width: 560px; margin: 40px auto; background: #fff; border-radius: 16px; padding: 40px; border: 1px solid #e2e8f0; }
    .badge { display: inline-block; background: #fee2e2; color: #dc2626; font-size: 12px; font-weight: 700; padding: 4px 12px; border-radius: 999px; margin-bottom: 20px; }
    h2 { color: #0f172a; margin: 0 0 12px; }
    p { color: #475569; line-height: 1.6; }
    .reason { background: #fef2f2; border-left: 4px solid #ef4444; border-radius: 8px; padding: 16px 20px; margin: 20px 0; color: #7f1d1d; }
    .footer { margin-top: 32px; font-size: 12px; color: #94a3b8; }
  </style>
</head>
<body>
  <div class="card">
    <span class="badge">Booth Rejected</span>
    <h2>Your booth application was not approved</h2>
    <p>Hi <strong>{{companyName}}</strong>,</p>
    <p>
      Your booth <strong>{{boothName}}</strong> for the expo
      <strong>{{expoName}}</strong> has been reviewed and was not approved at this time.
    </p>
    {{#if rejectionReason}}
    <div class="reason">
      <strong>Reason provided:</strong><br />
      {{rejectionReason}}
    </div>
    {{/if}}
    <p>
      You may update your booth details and resubmit for review. If you have questions,
      please contact the expo organizer.
    </p>
    <div class="footer">ExpoVerse - This is an automated notification</div>
  </div>
</body>
</html>